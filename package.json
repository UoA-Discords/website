{
    "name": "uoa-discords-website",
    "private": true,
    "workspaces": [
        "shared"
    ],
    "version": "1.0.0",
    "repository": "https://github.com/UoA-Discords/website.git",
    "author": "NachoToast <32235595+NachoToast@users.noreply.github.com>",
    "license": "MIT",
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "lint": "eslint --ext .ts --ext .tsx src --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "check-all": "yarn lint && yarn typecheck && yarn test"
    },
    "dependencies": {
        "@emotion/react": "^11.10.0",
        "@emotion/styled": "^11.10.0",
        "@fontsource/roboto": "^4.5.8",
        "@mui/icons-material": "^5.8.4",
        "@mui/material": "^5.10.0",
        "@reduxjs/toolkit": "^1.8.1",
        "@testing-library/jest-dom": "^5.16.4",
        "@testing-library/react": "^13.0.1",
        "@testing-library/user-event": "^14.1.1",
        "@types/jest": "^27.4.1",
        "@types/node": "^17.0.25",
        "@types/react": "^18.0.6",
        "@types/react-dom": "^18.0.2",
        "axios": "^0.27.2",
        "discord-api-types": "^0.37.0",
        "react": "^18.2.0",
        "react-cookie": "^4.1.1",
        "react-dom": "^18.2.0",
        "react-redux": "^8.0.1",
        "react-router-dom": "^6.3.0",
        "react-scripts": "5.0.1",
        "typescript": "^4.6.0",
        "uuid": "^8.3.2"
    },
    "devDependencies": {
        "@types/uuid": "^8.3.4",
        "eslint-config-prettier": "^8.5.0",
        "prettier": "^2.7.1"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "jest": {
        "testMatch": [
            "**/__tests__/**/*.[jt]s?(x)",
            "**/?(*.)+(spec|test).[jt]s?(x)",
            "!**/shared/**"
        ]
    }
}
